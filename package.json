{
  "name": "prosa",
  "productName": "Prosa",
  "version": "2.3.0",
  "author": "Rodrigo Brito <rodrigo@w3ti.com.br>",
  "license": "GPL-3.0-or-later",
  "description": "Editor de texto moderno ",
  "homepage": "https://github.com/britors/Prosa",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/britors/Prosa.git"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:e2e": "npm run build && node --import tsx --test tests/e2e/*.test.ts",
    "dist": "npm run build && electron-builder",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "br.com.Rodrigo Brito.prosa",
    "productName": "Prosa",
    "copyright": "© 2026 Rodrigo Brito",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "deb",
        "rpm",
        "pacman",
        "AppImage"
      ],
      "category": "Office",
      "icon": "build/icon.png",
      "maintainer": "Rodrigo Brito <rodrigo@w3ti.com.br>",
      "vendor": "Rodrigo Brito",
      "synopsis": "Editor de texto moderno — suíte Rodrigo Brito",
      "description": "Prosa — processador de texto moderno, open source e em modo escuro, parte da suíte de escritório Rodrigo Brito."
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Prosa-Setup-${version}.${ext}",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "shortcutName": "Prosa"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    }
  },
  "dependencies": {
    "@tiptap/core": "^2.11.5",
    "@tiptap/extension-character-count": "^2.11.5",
    "@tiptap/extension-color": "^2.11.5",
    "@tiptap/extension-font-family": "^2.11.5",
    "@tiptap/extension-highlight": "^2.11.5",
    "@tiptap/extension-image": "^2.11.5",
    "@tiptap/extension-link": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-subscript": "^2.11.5",
    "@tiptap/extension-superscript": "^2.11.5",
    "@tiptap/extension-table": "^2.11.5",
    "@tiptap/extension-table-cell": "^2.11.5",
    "@tiptap/extension-table-header": "^2.11.5",
    "@tiptap/extension-table-row": "^2.11.5",
    "@tiptap/extension-task-item": "^2.11.5",
    "@tiptap/extension-task-list": "^2.11.5",
    "@tiptap/extension-text-align": "^2.11.5",
    "@tiptap/extension-text-style": "^2.11.5",
    "@tiptap/extension-typography": "^2.11.5",
    "@tiptap/extension-underline": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "@xmldom/xmldom": "^0.9.10",
    "chokidar": "^5.0.0",
    "docx": "^9.1.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "font-list": "^1.6.0",
    "jszip": "^3.10.1",
    "lucide-static": "^1.17.0",
    "mammoth": "^1.9.0",
    "marked": "^15.0.7",
    "tiptap-pagination-plus": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "playwright-core": "^1.61.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "allowScripts": {
    "electron@34.5.8": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true
  }
}
